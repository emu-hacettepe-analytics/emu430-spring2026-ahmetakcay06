library(dslabs)
library(dplyr)
data("polls_us_election_2016")
df <- polls_us_election_2016
my_first <- "Ahmet"
my_birth_year <- 2000
k <- (nchar(my_first) + my_birth_year) %% 15 + 8
k
if (k %% 2 == 0) {
head(df, k)
} else {
tail(df, k)
}
if (k %% 2 == 0) {
head(df, k)
} else {
tail(df, k)
}
total_na <- sum(is.na(df))
total_na
na_per_column <- sort(colSums(is.na(df)), decreasing = TRUE)
head(na_per_column, 8)
new_df <- df
num_cols <- sapply(new_df, is.numeric)
new_df[num_cols] <- lapply(new_df[num_cols], function(x) {
x[is.na(x)] <- my_birth_year + k
x
})
char_fac_cols <- sapply(new_df, function(x) is.character(x) || is.factor(x))
new_df[char_fac_cols] <- lapply(new_df[char_fac_cols], function(x) {
x <- as.character(x)
x[is.na(x)] <- paste0(my_first, "_", k)
x
})
